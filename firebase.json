{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/*.py",
      "**/*.md",
      ".git/**",
      ".github/**"
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/app.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|json)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=300"
          }
        ]
      }
    ]
  }
}
